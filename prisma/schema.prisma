generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String     @id @default(uuid())
  firstName            String
  lastName             String
  email                String     @unique
  telephone            String
  jobTitle             String?
  company              String?
  professionRole       String
  reason               String
  hashedPassword       String
  securityQuestion     String
  hashedSecurityAnswer String
  mustSetSecurityQuestion Boolean @default(false)
  systemRole           SystemRole @default(USER)
  lastLoginAt          DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  accounts             Account[]
  projects             Project[]
  sessions             Session[]
  projectMemberships   TeamMember[]
  passwordResetTokens   PasswordResetToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}

model Project {
  id            String            @id @default(uuid())
  projectNumber Int               @unique @default(autoincrement())
  projectName   String
  contactName   String
  contactEmail  String
  telephone     String
  firmName      String?
  ownerName     String?
  address1      String?
  address2      String?
  city          String?
  state         String?
  zip           String?
  country       String            @default("United States")
  buildingArea  String?
  siteArea      String?
  certification String            @default("Guided Certification")
  services      String[]          @default([])
  status        ProjectStatus     @default(ONGOING)
  score         Float             @default(0)
  legacyApplicableCredits Float?
  legacyEarnedCredits     Float?
  legacyBonusCredits      Float?
  legacyAwardPercentage   Float?
  legacyChapterApplicable String?
  legacyChapterEarned     String?
  userId        String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     ProjectResponse[]
  facilityUses  FacilityUse[]     @relation("FacilityUseToProject")
  sectionToggles SectionToggle[]
  teamMembers    TeamMember[]
  submissions    ProjectSubmission[]

  @@index([userId])
  @@index([status])
}

model TeamMember {
  id         String         @id @default(uuid())
  projectId  String
  userId     String?
  email      String         // Track by email for invites
  permission TeamPermission @default(VIEWER)
  role       ProjectRole    @default(ARCHITECT)
  status     TeamStatus     @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([projectId, email])
  @@index([userId])
  @@index([email])
}

enum TeamPermission {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectRole {
  PROJECT_MANAGER
  ARCHITECT
  CONSULTANT
  DEVELOPMENT
  OWNERSHIP
  HR
  ADVOCATE
}

enum TeamStatus {
  ACTIVE
  PENDING
}

model SectionToggle {
  id        String   @id @default(uuid())
  projectId String
  sectionId String
  isEnabled Boolean  @default(true)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([projectId, sectionId])
}

model Chapter {
  id           String    @id @default(uuid())
  number       String    @unique
  title        String
  totalCredits Float
  archivedAt   DateTime?
  sections     Section[]
}

model Section {
  id                  String        @id @default(uuid())
  number              String
  title               String
  totalCredits        Float
  chapterId           String
  minPoints1          Int           @default(0)
  minPoints2          Int           @default(0)
  minPoints3          Int           @default(0)
  detailedInstruction String?
  archivedAt          DateTime?
  chapter             Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  solutions           Solution[]
  subSections         SubSection[]
  facilityUses        FacilityUse[] @relation("FacilityUseToSection")
  sectionToggles      SectionToggle[]

  @@unique([chapterId, number])
}

model SubSection {
  id           String     @id @default(uuid())
  number       String
  title        String
  totalCredits Float
  sectionId    String
  archivedAt   DateTime?
  solutions    Solution[]
  section      Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, number])
}

model Solution {
  id             String            @id @default(uuid())
  refId          String
  standardNumber String            @unique
  text           String
  points         Float             @default(0)
  isMandatory    Boolean           @default(false)
  instruction    String?
  archivedAt     DateTime?
  sectionId      String
  subSectionId   String?
  figures        Figure[]
  responses      ProjectResponse[]
  section        Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subSection     SubSection?       @relation(fields: [subSectionId], references: [id])
  goals          Goal[]            @relation("GoalToSolution")
  phases         Phase[]           @relation("PhaseToSolution")
}

model Figure {
  id         String   @id @default(uuid())
  solutionId String
  label      String
  number     String?
  caption    String?
  altTag     String?
  url        String?
  archivedAt DateTime?
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
}

model Goal {
  id        String     @id @default(uuid())
  abbr      String     @unique
  text      String
  archivedAt DateTime?
  solutions Solution[] @relation("GoalToSolution")
}

model Phase {
  id        String     @id @default(uuid())
  name      String     @unique
  archivedAt DateTime?
  solutions Solution[] @relation("PhaseToSolution")
}

model FacilityUse {
  id       String    @id @default(uuid())
  name     String    @unique
  archivedAt DateTime?
  projects Project[] @relation("FacilityUseToProject")
  sections Section[] @relation("FacilityUseToSection")
}

model ProjectResponse {
  id          String         @id @default(uuid())
  projectId   String
  solutionId  String
  status      ResponseStatus @default(NOT_IMPLEMENTED)
  notes       String?
  evidenceUrl String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  solution    Solution       @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@unique([projectId, solutionId])
}

model ProjectSubmission {
  id          String           @id @default(uuid())
  projectId   String
  tokenHash   String           @unique
  status      SubmissionStatus @default(PENDING)
  submittedTo String
  approvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

enum SystemRole {
  USER
  ADMIN
}

enum ProjectStatus {
  ONGOING
  IN_REVIEW
  COMPLETED
  INACTIVE
}

enum ResponseStatus {
  IMPLEMENTED
  NOT_IMPLEMENTED
  PARTIAL
  NOT_APPLICABLE
}

enum SubmissionStatus {
  PENDING
  APPROVED
}
