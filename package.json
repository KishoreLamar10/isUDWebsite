{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/clean-next-cache.cjs",
    "dev": "next dev -p 3001",
    "prebuild": "node scripts/guard-dev-server.cjs && node scripts/clean-next-cache.cjs",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "smoke": "node scripts/check-css-assets.cjs",
    "figures:import": "node scripts/import-figure-images.cjs",
    "legacy:dry-run": "node scripts/import-legacy-data.cjs",
    "legacy:import": "node scripts/import-legacy-data.cjs --apply"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.1.4",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "pg": "^8.13.1",
    "prisma": "5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.13.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
